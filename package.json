{
  "name": "feedforge",
  "version": "1.0.0",
  "description": "Local-first editorial radar for open source and technology news.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "vite build && tsc --noEmit -p tsconfig.json",
    "build:web": "vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "start": "tsx src/server.ts",
    "test": "vitest run",
    "lint": "tsc --noEmit -p tsconfig.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:push": "prisma db push",
    "crawler:run": "tsx src/cli/crawler-run.ts"
  },
  "dependencies": {
    "@fastify/static": "^8.0.4",
    "@prisma/client": "^6.1.0",
    "cheerio": "^1.0.0",
    "fastify": "^5.2.0",
    "node-cron": "^3.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "rss-parser": "^3.13.0",
    "undici": "^6.21.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^2.1.8"
  }
}
